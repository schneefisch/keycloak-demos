{
  "realm": "app-access-demo",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "browserFlow": "restricted-browser",
  "directGrantFlow": "restricted-direct-grant",
  "roles": {
    "realm": [
      {
        "name": "grafana-access",
        "description": "Grants login access to Grafana"
      }
    ]
  },
  "groups": [
    {
      "name": "platform-team",
      "realmRoles": [
        "grafana-access"
      ]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@example.com",
      "firstName": "Alice",
      "lastName": "Engineer",
      "groups": [
        "/platform-team"
      ],
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@example.com",
      "firstName": "Bob",
      "lastName": "Marketing",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ]
    }
  ],
  "authenticationFlows": [
    {
      "alias": "restricted-browser",
      "description": "Browser flow with client-level access restriction via Authorization Services policies",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-cookie",
          "authenticatorFlow": false,
          "requirement": "ALTERNATIVE",
          "priority": 10
        },
        {
          "authenticatorFlow": true,
          "requirement": "ALTERNATIVE",
          "priority": 20,
          "flowAlias": "restricted-browser-forms"
        }
      ]
    },
    {
      "alias": "restricted-browser-forms",
      "description": "Username/password then client access check",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "auth-username-password-form",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10
        },
        {
          "authenticator": "restrict-client-auth-authenticator",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20,
          "authenticatorConfig": "restrict-client-auth-policy-mode"
        }
      ]
    },
    {
      "alias": "restricted-direct-grant",
      "description": "Direct grant flow with client-level access restriction via Authorization Services policies",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        {
          "authenticator": "direct-grant-validate-username",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 10
        },
        {
          "authenticator": "direct-grant-validate-password",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 20
        },
        {
          "authenticator": "restrict-client-auth-authenticator",
          "authenticatorFlow": false,
          "requirement": "REQUIRED",
          "priority": 30,
          "authenticatorConfig": "restrict-client-auth-policy-mode"
        }
      ]
    }
  ],
  "authenticatorConfig": [
    {
      "alias": "restrict-client-auth-policy-mode",
      "config": {
        "accessProviderId": "policy"
      }
    }
  ],
  "clientScopes": [
    {
      "name": "basic",
      "description": "OpenID Connect scope for sub and auth_time claims",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "consentRequired": false,
          "config": {
            "introspection.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "auth_time",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usersessionmodel-note-mapper",
          "consentRequired": false,
          "config": {
            "user.session.note": "AUTH_TIME",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "claim.name": "auth_time",
            "jsonType.label": "long"
          }
        }
      ]
    },
    {
      "name": "profile",
      "description": "OpenID Connect built-in scope: profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "description": "OpenID Connect built-in scope: email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "emailVerified",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "claim.name": "email_verified",
            "jsonType.label": "boolean"
          }
        }
      ]
    },
    {
      "name": "roles",
      "description": "OpenID Connect scope for user realm and client roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "user.attribute": "foo",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "grafana",
      "name": "Grafana",
      "description": "Grafana OAuth client — access restricted via Authorization Services policies",
      "enabled": true,
      "publicClient": false,
      "secret": "grafana-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles-as-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "claim.name": "groups",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ],
      "authorizationSettings": {
        "allowRemoteResourceManagement": false,
        "policyEnforcementMode": "ENFORCING",
        "decisionStrategy": "UNANIMOUS",
        "resources": [
          {
            "name": "Keycloak Client Resource",
            "displayName": "Keycloak Client Resource",
            "type": "urn:grafana:resources:client-access",
            "ownerManagedAccess": false
          }
        ],
        "policies": [
          {
            "name": "grafana-access-only",
            "description": "Requires the grafana-access realm role",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "roles": "[{\"id\":\"grafana-access\",\"required\":true}]"
            }
          },
          {
            "name": "grafana-access-permission",
            "description": "Grants access to Keycloak Client Resource for users with the grafana-access role",
            "type": "resource",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"Keycloak Client Resource\"]",
              "applyPolicies": "[\"grafana-access-only\"]"
            }
          }
        ],
        "scopes": []
      }
    }
  ]
}
